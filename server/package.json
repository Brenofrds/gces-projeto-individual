{
  "name": "mk.js-server",
  "version": "0.0.1",
  "private": true,
  "author": "Minko Gechev @mgechev",
  "description": "Node.js server for mk.js",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --legacy-watch --watch . server.js",
    "lint": "eslint server.js games.js database.js",
    "test": "node --test test/games.test.js",
    "test:fuzz": "node --test fuzz/games.fuzz.test.js",
    "test:coverage": "c8 --reporter=lcov --reporter=text --check-coverage --lines 80 --functions 80 --branches 80 --statements 80 node --test test/*.test.js fuzz/*.test.js",
    "build": "node --check server.js && node --check games.js && node --check database.js"
  },
  "dependencies": {
    "express": "^4.18.3",
    "pg": "^8.11.5",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "c8": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-security": "^4.0.0",
    "fast-check": "^4.8.0",
    "nodemon": "^3.1.0"
  }
}
